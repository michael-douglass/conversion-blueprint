# MIME types para módulos ES e JS (evita application/octet-stream)
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
</IfModule>

# SPA: encaminhar todas as rotas para index.html (React Router)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Segurança e cache (opcional)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ico|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
</IfModule>
